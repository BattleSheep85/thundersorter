{
  "manifest_version": 3,
  "name": "Thundersorter",
  "version": "0.3.0",
  "description": "Auto-tag emails by sending subject, sender, and body text to an AI provider you choose (Gemini, OpenAI, Anthropic, etc). No data is sent until you consent and configure a provider.",
  "author": "Chris",
  "permissions": [
    "messagesRead",
    "accountsRead",
    "messagesTags",
    "messagesTagsList",
    "messagesUpdate",
    "storage",
    "menus"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://api.fireworks.ai/*",
    "https://openrouter.ai/*",
    "https://api.together.xyz/*",
    "https://api.groq.com/*",
    "http://localhost/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_title": "Classify folder with Thundersorter",
    "default_icon": "icons/icon64.png"
  },
  "options_ui": {
    "page": "options/options.html"
  },
  "icons": {
    "64": "icons/icon64.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "thundersorter@local",
      "update_url": "https://raw.githubusercontent.com/BattleSheep85/thundersorter/main/updates.json",
      "strict_min_version": "128.0"
    }
  }
}
