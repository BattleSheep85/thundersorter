{
  "manifest_version": 3,
  "name": "Thundersorter",
  "version": "0.1.0",
  "description": "Auto-tag emails using Google Gemini AI",
  "author": "Chris",
  "permissions": [
    "messagesRead",
    "accountsRead",
    "messagesTags",
    "messagesTagsList",
    "messagesUpdate",
    "storage",
    "menus"
  ],
  "host_permissions": [
    "http://127.0.0.1:8465/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_title": "Classify folder with Thundersorter",
    "default_icon": "icons/icon64.png"
  },
  "options_ui": {
    "page": "options/options.html"
  },
  "icons": {
    "64": "icons/icon64.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "thundersorter@local",
      "strict_min_version": "128.0"
    }
  }
}
